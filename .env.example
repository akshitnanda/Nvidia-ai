NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LOCAL_NIM_BASE_URL=http://localhost:8000/v1
NVIDIA_PROVIDER_MODE=serverless
